round:#1f2a33;color:#f2efe8;padding:14px max(24px,4vw);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px\">\n    <div style=\"display:flex;align-items:center;gap:12px\">\n      <div style=\"width:36px;height:36px;border:2px solid #f2efe8;display:grid;place-items:center;font-weight:800;font-size:16px\">SJ<\u002Fdiv>\n      <div>\n        <div style=\"font-weight:700;font-size:14px;line-height:1.2\">Subdirección para la Juventud<\u002Fdiv>\n        <div style=\"font-size:11px;letter-spacing:.06em;text-transform:uppercase;color:#c7bfa8\">Secretaría Distrital de Integración Social<\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n    <div style=\"font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:#c7bfa8;border:1px solid #4a5560;padding:6px 12px\">Rendición de cuentas · Corte {{ cutoff }}<\u002Fdiv>\n  <\u002Fdiv>\n\n  <div style=\"padding:44px max(24px,4vw) 30px;max-width:1240px;margin:0 auto\">\n    <p style=\"margin:0 0 10px;font-size:12px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#5c6570\">Informe para subdirectores locales<\u002Fp>\n    <h1 style=\"margin:0 0 14px;font-size:clamp(30px,3.6vw,46px);line-height:1.06;font-weight:800;max-width:900px\">Caracterización de personas atendidas por servicio y localidad<\u002Fh1>\n    <p style=\"margin:0 0 26px;font-size:16px;line-height:1.6;max-width:760px;color:#333d45\">Este informe presenta, para cada localidad, quiénes fueron atendidos por Casas de Juventud, el Servicio Forjar Restaurativo y Jóvenes con Oportunidades durante {{ cutoff }}. Úselo como insumo para su ejercicio de rendición de cuentas local.<\u002Fp>\n\n    <div style=\"border:1px solid #dcd6c9;background:#ffffff;padding:20px;display:flex;align-items:end;gap:22px;flex-wrap:wrap\" class=\"no-print\">\n      <div>\n        <label for=\"localidad\" style=\"display:block;font-size:11px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:#5c6570;margin-bottom:6px\">Seleccione su localidad<\u002Flabel>\n        <sc-raw-select id=\"localidad\" value=\"{{ selectedLocality }}\" sc-camel-on-change=\"{{ onLocalityChange }}\" style=\"font:600 15px 'Public Sans',Arial,sans-serif;padding:10px 12px;border:1px solid #1f2a33;background:#fff;color:#1f2a33;min-width:260px\">\n          <sc-for list=\"{{ localidades }}\" as=\"loc\" hint-placeholder-count=\"21\">\n            <option value=\"{{ loc }}\">{{ loc }}<\u002Foption>\n          <\u002Fsc-for>\n        <\u002Fsc-raw-select>\n      <\u002Fdiv>\n      <button sc-camel-on-click=\"{{ onPrint }}\" style=\"border:1px solid #1f2a33;background:#1f2a33;color:#fff;font:700 13px 'Public Sans',Arial,sans-serif;letter-spacing:.03em;padding:11px 16px;cursor:pointer\">Imprimir / Exportar PDF<\u002Fbutton>\n    <\u002Fdiv>\n  <\u002Fdiv>\n\n  <div style=\"background:#eee9db;border-top:1px solid #dcd6c9;border-bottom:1px solid #dcd6c9;padding:12px max(24px,4vw);display:flex;gap:8px;align-items:baseline;flex-wrap:wrap\">\n    <span style=\"font-size:12px;color:#5c6570\">Vista actual:<\u002Fspan>\n    <strong style=\"font-size:14px\">{{ selectedLocality }}<\u002Fstrong>\n  <\u002Fdiv>\n\n  <nav class=\"no-print\" style=\"padding:14px max(24px,4vw);display:flex;gap:26px;flex-wrap:wrap;border-bottom:1px solid #dcd6c9\">\n    <a href=\"#casas\" style=\"font-weight:700;font-size:13px;letter-spacing:.03em;text-decoration:none\">Casas de Juventud<\u002Fa>\n    <a href=\"#forjar\" style=\"font-weight:700;font-size:13px;letter-spacing:.03em;text-decoration:none\">Forjar Restaurativo<\u002Fa>\n    <a href=\"#jco\" style=\"font-weight:700;font-size:13px;letter-spacing:.03em;text-decoration:none\">Jóvenes con Oportunidades<\u002Fa>\n  <\u002Fnav>\n\n  <main style=\"max-width:1240px;margin:0 auto;padding:0 max(24px,4vw)\">\n\n    <section id=\"casas\" class=\"service-section\" style=\"padding:46px 0;border-bottom:1px solid #dcd6c9\">\n      <div style=\"display:flex;justify-content:space-between;gap:24px;flex-wrap:wrap;align-items:start;margin-bottom:18px\">\n        <div style=\"display:flex;gap:16px;align-items:baseline\">\n          <span style=\"font-size:40px;font-weight:800;color:#dcd6c9\">01<\u002Fspan>\n          <h2 style=\"margin:0;font-size:28px;font-weight:800\">Casas de Juventud<\u002Fh2>\n        <\u002Fdiv>\n        <div style=\"text-align:right\">\n          <div style=\"font-size:32px;font-weight:800\">{{ casas.totalFmt }}<\u002Fdiv>\n          <div style=\"font-size:11px;letter-spacing:.06em;text-transform:uppercase;color:#5c6570\">Personas únicas atendidas<\u002Fdiv>\n        <\u002Fdiv>\n      <\u002Fdiv>\n\n      <div style=\"border:1px solid #dcd6c9;background:#fff;padding:18px 20px;margin-bottom:22px\">\n        <p style=\"margin:0 0 6px;font-size:11px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:#3c6e63\">Qué es este servicio<\u002Fp>\n        <p style=\"margin:0;font-size:15px;line-height:1.6;color:#2b3339\">Casas de Juventud son espacios comunitarios de la Secretaría Distrital de Integración Social, presentes en las localidades de Bogotá. Atienden a adolescentes y jóvenes de 14 a 28 años con procesos de orientación psicosocial, formación en habilidades para la vida, arte y participación, con el objetivo de fortalecer sus proyectos de vida y su permanencia en el territorio.<\u002Fp>\n      <\u002Fdiv>\n\n      <div style=\"display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:#dcd6c9;border:1px solid #dcd6c9;margin-bottom:22px\">\n        <sc-for list=\"{{ casas.kpis }}\" as=\"k\" hint-placeholder-count=\"4\">\n          <div style=\"background:#fff;padding:16px\">\n            <div style=\"font-size:11px;font-weight:700;letter-spacing:.04em;text-transform:uppercase;color:#5c6570;margin-bottom:8px\">{{ k.label }}<\u002Fdiv>\n            <div style=\"font-size:22px;font-weight:800;margin-bottom:4px\">{{ k.value }}<\u002Fdiv>\n            <div style=\"font-size:12px;color:#5c6570\">{{ k.note }}<\u002Fdiv>\n          <\u002Fdiv>\n        <\u002Fsc-for>\n      <\u002Fdiv>\n\n      <div style=\"display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:20px\">\n        <div style=\"border:1px solid #dcd6c9;background:#fff;padding:18px\">\n          <div style=\"display:flex;justify-content:space-between;margin-bottom:12px\"><h3 style=\"margin:0;font-size:15px;font-weight:700\">Personas por rango etario<\u002Fh3><span style=\"font-size:11px;color:#5c6570\">% pob. 14–28 años<\u002Fspan><\u002Fdiv>\n          <sc-for list=\"{{ casas.edadBars }}\" as=\"b\" hint-placeholder-count=\"4\">\n            <div style=\"margin-bottom:10px\">\n              <div style=\"display:flex;justify-content:space-between;font-size:13px;margin-bottom:4px\"><span>{{ b.label }}<\u002Fspan><b>{{ b.valueFmt }} <span style=\"color:#5c6570;font-weight:600\">{{ b.pctLabel }}<\u002Fspan><\u002Fb><\u002Fdiv>\n              <div style=\"height:6px;background:#eee9db\"><div style=\"height:100%;width:{{ b.widthPct }}%;background:#3c6e63\"><\u002Fdiv><\u002Fdiv>\n            <\u002Fdiv>\n          <\u002Fsc-for>\n        <\u002Fdiv>\n        <div style=\"border:1px solid #dcd6c9;background:#fff;padding:18px\">\n          <div style=\"display:flex;justify-content:space-between;margin-bottom:12px\"><h3 style=\"margin:0;font-size:15px;font-weight:700\">Personas según sexo<\u002Fh3><span style=\"font-size:11px;color:#5c6570\">% sobre información válida<\u002Fspan><\u002Fdiv>\n          <sc-for list=\"{{ casas.sexoBars }}\" as=\"b\" hint-placeholder-count=\"3\">\n            <div style=\"margin-bottom:10px\">\n              <div style=\"display:flex;justify-content:space-between;font-size:13px;margin-bottom:4px\"><span>{{ b.label }}<\u002Fspan><b>{{ b.valueFmt }} <span style=\"color:#5c6570;font-weight:600\">{{ b.pctLabel }}<\u002Fspan><\u002Fb><\u002Fdiv>\n              <div style=\"height:6px;background:#eee9db\"><div style=\"height:100%;width:{{ b.widthPct }}%;background:#7a3b56\"><\u002Fdiv><\u002Fdiv>\n            <\u002Fdiv>\n          <\u002Fsc-for>\n        <\u002Fdiv>\n        <div style=\"border:1px solid #dcd6c9;background:#fff;padding:18px\">\n          <div style=\"display:flex;justify-content:space-between;margin-bottom:12px\"><h3 style=\"margin:0;font-size:15px;font-weight:700\">Personas según grupo Sisbén<\u002Fh3><span style=\"font-size:11px;color:#5c6570\">% sobre información válida<\u002Fspan><\u002Fdiv>\n          <sc-for list=\"{{ casas.sisbenBars }}\" as=\"b\" hint-placeholder-count=\"5\">\n            <div style=\"margin-bottom:10px\">\n              <div style=\"display:flex;justify-content:space-between;font-size:13px;margin-bottom:4px\"><span>{{ b.label }}<\u002Fspan><b>{{ b.valueFmt }} <span style=\"color:#5c6570;font-weight:600\">{{ b.pctLabel }}<\u002Fspan><\u002Fb><\u002Fdiv>\n              <div style=\"height:6px;background:#eee9db\"><div style=\"height:100%;width:{{ b.widthPct }}%;background:#8a5a2b\"><\u002Fdiv><\u002Fdiv>\n            <\u002Fdiv>\n          <\u002Fsc-for>\n        <\u002Fdiv>\n      <\u002Fdiv>\n\n      <div style=\"border-top:2px solid #3c6e63;background:#f6f5f1;padding:16px 20px\">\n        <strong style=\"display:block;font-size:11px;letter-spacing:.06em;text-transform:uppercase;color:#3c6e63;margin-bottom:6px\">Lectura principal<\u002Fstrong>\n        <p style=\"margin:0;font-size:14px;line-height:1.6\" sc-camel-dangerously-set-inner-h-t-m-l=\"{{ casas.insightHtml }}\"><\u002Fp>\n      <\u002Fdiv>\n    <\u002Fsection>\n\n    <section id=\"forjar\" class=\"service-section\" style=\"padding:46px 0;border-bottom:1px solid #dcd6c9\">\n      <div style=\"display:flex;justify-content:space-between;gap:24px;flex-wrap:wrap;align-items:start;margin-bottom:18px\">\n        <div style=\"display:flex;gap:16px;align-items:baseline\">\n          <span style=\"font-size:40px;font-weight:800;color:#dcd6c9\">02<\u002Fspan>\n          <h2 style=\"margin:0;font-size:28px;font-weight:800\">Servicio Forjar Restaurativo<\u002Fh2>\n        <\u002Fdiv>\n        <div style=\"text-align:right\">\n          <div style=\"font-size:32px;font-weight:800\">{{ forjar.totalFmt }}<\u002Fdiv>\n          <div style=\"font-size:11px;letter-spacing:.06em;text-transform:uppercase;color:#5c6570\">Personas únicas atendidas<\u002Fdiv>\n        <\u002Fdiv>\n      <\u002Fdiv>\n\n      <div style=\"border:1px solid #dcd6c9;background:#fff;padding:18px 20px;margin-bottom:22px\">\n        <p style=\"margin:0 0 6px;font-size:11px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:#8a5a2b\">Qué es este servicio<\u002Fp>\n        <p style=\"margin:0;font-size:15px;line-height:1.6;color:#2b3339\">El Servicio Forjar Restaurativo brinda atención integral y acompañamiento psicosocial a adolescentes y jóvenes vinculados al Sistema de Responsabilidad Penal para Adolescentes (SRPA). Su objetivo es apoyar procesos de justicia restaurativa que favorezcan la reincorporación familiar, social y comunitaria.<\u002Fp>\n      <\u002Fdiv>\n\n      <div style=\"display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:#dcd6c9;border:1px solid #dcd6c9;margin-bottom:22px\">\n        <sc-for list=\"{{ forjar.kpis }}\" as=\"k\" hint-placeholder-count=\"4\">\n          <div style=\"background:#fff;padding:16px\">\n            <div style=\"font-size:11px;font-weight:700;letter-spacing:.04em;text-transform:uppercase;color:#5c6570;margin-bottom:8px\">{{ k.label }}<\u002Fdiv>\n            <div style=\"font-size:22px;font-weight:800;margin-bottom:4px\">{{ k.value }}<\u002Fdiv>\n            <div style=\"font-size:12px;color:#5c6570\">{{ k.note }}<\u002Fdiv>\n          <\u002Fdiv>\n        <\u002Fsc-for>\n      <\u002Fdiv>\n\n      <div style=\"display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:20px\">\n        <div style=\"border:1px solid #dcd6c9;background:#fff;padding:18px\">\n          <div style=\"display:flex;justify-content:space-between;margin-bottom:12px\"><h3 style=\"margin:0;font-size:15px;font-weight:700\">Personas por rango etario<\u002Fh3><span style=\"font-size:11px;color:#5c6570\">% pob. 14–28 años<\u002Fspan><\u002Fdiv>\n          <sc-for list=\"{{ forjar.edadBars }}\" as=\"b\" hint-placeholder-count=\"4\">\n            <div style=\"margin-bottom:10px\">\n              <div style=\"display:flex;justify-content:space-between;font-size:13px;margin-bottom:4px\"><span>{{ b.label }}<\u002Fspan><b>{{ b.valueFmt }} <span style=\"color:#5c6570;font-weight:600\">{{ b.pctLabel }}<\u002Fspan><\u002Fb><\u002Fdiv>\n              <div style=\"height:6px;background:#eee9db\"><div style=\"height:100%;width:{{ b.widthPct }}%;background:#8a5a2b\"><\u002Fdiv><\u002Fdiv>\n            <\u002Fdiv>\n          <\u002Fsc-for>\n        <\u002Fdiv>\n        <div style=\"border:1px solid #dcd6c9;background:#fff;padding:18px\">\n          <div style=\"display:flex;justify-content:space-between;margin-bottom:12px\"><h3 style=\"margin:0;font-size:15px;font-weight:700\">Personas según sexo<\u002Fh3><span style=\"font-size:11px;color:#5c6570\">% sobre información válida<\u002Fspan><\u002Fdiv>\n          <sc-for list=\"{{ forjar.sexoBars }}\" as=\"b\" hint-placeholder-count=\"3\">\n            <div style=\"margin-bottom:10px\">\n              <div style=\"display:flex;justify-content:space-between;font-size:13px;margin-bottom:4px\"><span>{{ b.label }}<\u002Fspan><b>{{ b.valueFmt }} <span style=\"color:#5c6570;font-weight:600\">{{ b.pctLabel }}<\u002Fspan><\u002Fb><\u002Fdiv>\n              <div style=\"height:6px;background:#eee9db\"><div style=\"height:100%;width:{{ b.widthPct }}%;background:#7a3b56\"><\u002Fdiv><\u002Fdiv>\n            <\u002Fdiv>\n          <\u002Fsc-for>\n        <\u002Fdiv>\n        <div style=\"border:1px solid #dcd6c9;background:#fff;padding:18px\">\n          <div style=\"display:flex;justify-content:space-between;margin-bottom:12px\"><h3 style=\"margin:0;font-size:15px;font-weight:700\">Personas según grupo Sisbén<\u002Fh3><span style=\"font-size:11px;color:#5c6570\">% sobre información válida<\u002Fspan><\u002Fdiv>\n          <sc-for list=\"{{ forjar.sisbenBars }}\" as=\"b\" hint-placeholder-count=\"5\">\n            <div style=\"margin-bottom:10px\">\n              <div style=\"display:flex;justify-content:space-between;font-size:13px;margin-bottom:4px\"><span>{{ b.label }}<\u002Fspan><b>{{ b.valueFmt }} <span style=\"color:#5c6570;font-weight:600\">{{ b.pctLabel }}<\u002Fspan><\u002Fb><\u002Fdiv>\n              <div style=\"height:6px;background:#eee9db\"><div style=\"height:100%;width:{{ b.widthPct }}%;background:#3c6e63\"><\u002Fdiv><\u002Fdiv>\n            <\u002Fdiv>\n          <\u002Fsc-for>\n        <\u002Fdiv>\n      <\u002Fdiv>\n\n      <div style=\"border-top:2px solid #8a5a2b;background:#f6f5f1;padding:16px 20px\">\n        <strong style=\"display:block;font-size:11px;letter-spacing:.06em;text-transform:uppercase;color:#8a5a2b;margin-bottom:6px\">Lectura principal<\u002Fstrong>\n        <p style=\"margin:0;font-size:14px;line-height:1.6\" sc-camel-dangerously-set-inner-h-t-m-l=\"{{ forjar.insightHtml }}\"><\u002Fp>\n      <\u002Fdiv>\n    <\u002Fsection>\n\n    <section id=\"jco\" class=\"service-section\" style=\"padding:46px 0\">\n      <div style=\"display:flex;justify-content:space-between;gap:24px;flex-wrap:wrap;align-items:start;margin-bottom:18px\">\n        <div style=\"display:flex;gap:16px;align-items:baseline\">\n          <span style=\"font-size:40px;font-weight:800;color:#dcd6c9\">03<\u002Fspan>\n          <h2 style=\"margin:0;font-size:28px;font-weight:800\">Jóvenes con Oportunidades<\u002Fh2>\n        <\u002Fdiv>\n        <div style=\"text-align:right\">\n          <div style=\"font-size:32px;font-weight:800\">{{ jco.totalFmt }}<\u002Fdiv>\n          <div style=\"font-size:11px;letter-spacing:.06em;text-transform:uppercase;color:#5c6570\">Jóvenes con primer pago<\u002Fdiv>\n        <\u002Fdiv>\n      <\u002Fdiv>\n\n      <div style=\"border:1px solid #dcd6c9;background:#fff;padding:18px 20px;margin-bottom:22px\">\n        <p style=\"margin:0 0 6px;font-size:11px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:#33547a\">Qué es este servicio<\u002Fp>\n        <p style=\"margin:0;font-size:15px;line-height:1.6;color:#2b3339\">Jóvenes con Oportunidades (JCO) conecta a jóvenes de 14 a 28 años con rutas de educación, formación para el trabajo y empleo, a través de entidades aliadas como el SENA, Atenea, la SDDE y la SED. Su objetivo es ampliar el acceso a educación superior, formación técnica y oportunidades de generación de ingresos.<\u002Fp>\n      <\u002Fdiv>\n\n      <div style=\"display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:#dcd6c9;border:1px solid #dcd6c9;margin-bottom:22px\">\n        <sc-for list=\"{{ jco.kpis }}\" as=\"k\" hint-placeholder-count=\"3\">\n          <div style=\"background:#fff;padding:16px\">\n            <div style=\"font-size:11px;font-weight:700;letter-spacing:.04em;text-transform:uppercase;color:#5c6570;margin-bottom:8px\">{{ k.label }}<\u002Fdiv>\n            <div style=\"font-size:22px;font-weight:800;margin-bottom:4px\">{{ k.value }}<\u002Fdiv>\n            <div style=\"font-size:12px;color:#5c6570\">{{ k.note }}<\u002Fdiv>\n          <\u002Fdiv>\n        <\u002Fsc-for>\n      <\u002Fdiv>\n\n      <div style=\"display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:20px\">\n        <div style=\"border:1px solid #dcd6c9;background:#fff;padding:18px\">\n          <div style=\"display:flex;justify-content:space-between;margin-bottom:12px\"><h3 style=\"margin:0;font-size:15px;font-weight:700\">Personas por rango etario<\u002Fh3><span style=\"font-size:11px;color:#5c6570\">% pob. 14–28 años<\u002Fspan><\u002Fdiv>\n          <sc-for list=\"{{ jco.edadBars }}\" as=\"b\" hint-placeholder-count=\"4\">\n            <div style=\"margin-bottom:10px\">\n              <div style=\"display:flex;justify-content:space-between;font-size:13px;margin-bottom:4px\"><span>{{ b.label }}<\u002Fspan><b>{{ b.valueFmt }} <span style=\"color:#5c6570;font-weight:600\">{{ b.pctLabel }}<\u002Fspan><\u002Fb><\u002Fdiv>\n              <div style=\"height:6px;background:#eee9db\"><div style=\"height:100%;width:{{ b.widthPct }}%;background:#33547a\"><\u002Fdiv><\u002Fdiv>\n            <\u002Fdiv>\n          <\u002Fsc-for>\n        <\u002Fdiv>\n        <div style=\"border:1px solid #dcd6c9;background:#fff;padding:18px\">\n          <div style=\"display:flex;justify-content:space-between;margin-bottom:12px\"><h3 style=\"margin:0;font-size:15px;font-weight:700\">Personas según entidad<\u002Fh3><span style=\"font-size:11px;color:#5c6570\">% sobre información válida<\u002Fspan><\u002Fdiv>\n          <sc-for list=\"{{ jco.entidadBars }}\" as=\"b\" hint-placeholder-count=\"5\">\n            <div style=\"margin-bottom:10px\">\n              <div style=\"display:flex;justify-content:space-between;font-size:13px;margin-bottom:4px\"><span>{{ b.label }}<\u002Fspan><b>{{ b.valueFmt }} <span style=\"color:#5c6570;font-weight:600\">{{ b.pctLabel }}<\u002Fspan><\u002Fb><\u002Fdiv>\n              <div style=\"height:6px;background:#eee9db\"><div style=\"height:100%;width:{{ b.widthPct }}%;background:#7a3b56\"><\u002Fdiv><\u002Fdiv>\n            <\u002Fdiv>\n          <\u002Fsc-for>\n        <\u002Fdiv>\n        <div style=\"border:1px solid #dcd6c9;background:#fff;padding:18px\">\n          <div style=\"display:flex;justify-content:space-between;margin-bottom:12px\"><h3 style=\"margin:0;font-size:15px;font-weight:700\">Personas según ruta<\u002Fh3><span style=\"font-size:11px;color:#5c6570\">% sobre información válida<\u002Fspan><\u002Fdiv>\n          <sc-for list=\"{{ jco.rutaBars }}\" as=\"b\" hint-placeholder-count=\"6\">\n            <div style=\"margin-bottom:10px\">\n              <div style=\"display:flex;justify-content:space-between;font-size:13px;margin-bottom:4px\"><span>{{ b.label }}<\u002Fspan><b>{{ b.valueFmt }} <span style=\"color:#5c6570;font-weight:600\">{{ b.pctLabel }}<\u002Fspan><\u002Fb><\u002Fdiv>\n              <div style=\"height:6px;background:#eee9db\"><div style=\"height:100%;width:{{ b.widthPct }}%;background:#8a5a2b\"><\u002Fdiv><\u002Fdiv>\n            <\u002Fdiv>\n          <\u002Fsc-for>\n        <\u002Fdiv>\n      <\u002Fdiv>\n\n      <div style=\"border-top:2px solid #33547a;background:#f6f5f1;padding:16px 20px\">\n        <strong style=\"display:block;font-size:11px;letter-spacing:.06em;text-transform:uppercase;color:#33547a;margin-bottom:6px\">Lectura principal<\u002Fstrong>\n        <p style=\"margin:0;font-size:14px;line-height:1.6\" sc-camel-dangerously-set-inner-h-t-m-l=\"{{ jco.insightHtml }}\"><\u002Fp>\n      <\u002Fdiv>\n    <\u002Fsection>\n\n  <\u002Fmain>\n\n  <footer style=\"max-width:1240px;margin:0 auto;padding:26px max(24px,4vw) 40px;border-top:1px solid #dcd6c9\"><\u002Ffooter>\n<\u002Fdiv>\n\n<\u002Fx-dc>\n<script type=\"text/x-dc\" data-dc-script=\"\">\nconst fmt = new Intl.NumberFormat('es-CO');\nconst pct = (n, d) => d ? `${(n / d * 100).toFixed(1).replace('.', ',')}%` : '0,0%';\nconst val = (a, l) => (a.find(x => x.label === l) || {}).value || 0;\nconst valid = (a, ex) => { ex = ex || ['Sin información']; return a.filter(x => ex.indexOf(x.label) === -1).reduce((s, x) => s + x.value, 0); };\nconst esc = s => String(s);\n\nfunction bars(items, den, excludeZero) {\n  const max = Math.max(1, ...items.map(x => x.value));\n  return items.filter(x => !excludeZero || x.value > 0).map(x => ({\n    label: x.label,\n    valueFmt: fmt.format(x.value),\n    pctLabel: pct(x.value, den),\n    widthPct: Math.round((x.value / max) * 1000) / 10\n  }));\n}\n\nclass Component extends DCLogic {\n  state = { selectedLocality: 'Todas las localidades' };\n\n  buildYouthService(key, label, index, totalLabel) {\n    const DATA = window.JUVENTUD_DATA;\n    const s = DATA.services[key];\n    const loc = this.state.selectedLocality;\n    const v = s.views[loc];\n    const youth = valid(v.edad, ['Sin información', 'Fuera del rango']);\n    const validAges = v.edad.filter(x => ['Sin información', 'Fuera del rango'].indexOf(x.label) === -1);\n    const top = [...validAges].sort((a, b) => b.value - a.value)[0];\n\n    const kpis = [\n      { label: totalLabel, value: fmt.format(v.total), note: 'Conteo distinto de persona' },\n      { label: 'Rango etario principal', value: top ? top.label : '—', note: top ? `${fmt.format(top.value)} personas` : 'Sin datos' },\n      { label: 'Personas con discapacidad', value: pct(v.discapacidad.value, v.discapacidad.denominator), note: `${fmt.format(v.discapacidad.value)} personas` }\n    ];\n    if (v.etnia) kpis.push({ label: 'Pertenencia étnica', value: pct(v.etnia.value, v.etnia.denominator), note: `${fmt.format(v.etnia.value)} personas` });\n\n    const locName = loc === 'Todas las localidades' ? 'el consolidado de Bogotá' : loc;\n    let insightHtml, secondBars = [], thirdBars = [];\n    if (key === 'jco') {\n      secondBars = bars(v.entidad, valid(v.entidad));\n      thirdBars = bars(v.ruta, valid(v.ruta));\n      const te = [...v.entidad].sort((a, b) => b.value - a.value)[0];\n      const tr = [...v.ruta].sort((a, b) => b.value - a.value)[0];\n      insightHtml = v.total\n        ? `En ${locName} se registraron <b>${fmt.format(v.total)}<\u002Fb> jóvenes con primer pago en JCO. La entidad con mayor participación fue <b>${esc(te ? te.label : '—')}<\u002Fb>, la ruta más frecuente fue <b>${esc(tr ? tr.label : '—')}<\u002Fb> y el <b>${pct(v.discapacidad.value, v.discapacidad.denominator)}<\u002Fb> correspondió a personas con discapacidad.`\n        : 'No se registran personas de este servicio en la localidad seleccionada.';\n    } else {\n      const sx = valid(v.sexo);\n      secondBars = bars(v.sexo, sx);\n      thirdBars = bars(v.sisben, valid(v.sisben));\n      const topS = [...v.sisben].filter(x => x.label !== 'Sin información').sort((a, b) => b.value - a.value)[0];\n      insightHtml = v.total\n        ? `En ${locName} se registraron <b>${fmt.format(v.total)}<\u002Fb> personas únicas. Entre quienes tienen información de sexo, el <b>${pct(val(v.sexo, 'Mujer'), sx)}<\u002Fb> fueron mujeres y el <b>${pct(val(v.sexo, 'Hombre'), sx)}<\u002Fb> hombres. El rango etario principal fue <b>${top ? top.label : '—'}<\u002Fb>${topS ? ` y el grupo Sisbén más frecuente fue <b>${topS.label}<\u002Fb>` : ''}.`\n        : 'No se registran personas de este servicio en la localidad seleccionada.';\n    }\n\n    return {\n      totalFmt: fmt.format(v.total),\n      kpis,\n      edadBars: bars(v.edad, youth, true),\n      sexoBars: key !== 'jco' ? secondBars : [],\n      sisbenBars: key !== 'jco' ? thirdBars : [],\n      entidadBars: key === 'jco' ? secondBars : [],\n      rutaBars: key === 'jco' ? thirdBars : [],\n      insightHtml: { __html: insightHtml }\n    };\n  }\n\n  handlePrint() { window.print(); }\n\n  renderVals() {\n    const DATA = window.JUVENTUD_DATA;\n    if (!DATA) return {};\n    return {\n      cutoff: DATA.metadata.cutoff,\n      localidades: ['Todas las localidades', ...DATA.metadata.localidades],\n      selectedLocality: this.state.selectedLocality,\n      onLocalityChange: e => this.setState({ selectedLocality: e.target.value }),\n      onPrint: () => this.handlePrint(),\n      casas: this.buildYouthService('casas', 'Casas de Juventud', 1, 'Personas únicas atendidas'),\n      forjar: this.buildYouthService('forjar', 'Servicio Forjar Restaurativo', 2, 'Personas únicas atendidas'),\n      jco: this.buildYouthService('jco', 'Jóvenes con Oportunidades', 3, 'Jóvenes con primer pago')\n    };\n  }\n}\n<\u002Fscript>\n\n\n<\u002Fbody><\u002Fhtml>"
  </script>
